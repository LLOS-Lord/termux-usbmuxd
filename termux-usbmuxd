#!/data/data/com.termux/files/usr/bin/bash
#
# termux-usbmuxd - Rootless usbmuxd management (Absolutely Stable Version)
#
set -euo pipefail

SOCKET="$PREFIX/var/run/usbmuxd"
PIDFILE="$PREFIX/var/run/usbmuxd.pid"
LOGFILE="$HOME/.termux-usbmuxd.log"
PROXY_BIN="$PREFIX/bin/usbmuxd_proxy"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Export default environment variables
export USBMUXD_SOCKET_ADDRESS="UNIX:$SOCKET"

get_devices() {
  termux-usb -l 2>/dev/null | jq -r '.[]' 2>/dev/null || echo ""
}

start_usbmuxd() {
  local device=${1:-""}
  
  if [[ -z "$device" ]]; then

log_info "Scanning USB devices..."

device=$(get_devices | head -n 1)

if [[ -z "$device" ]]; then

log_error "iPhone not found. Please plug in OTG cable."

exit 1

fi

fi

log_info "Requesting permission for $device..."

termux-usb -r "$device" || { log_error "Permission denied."; exit 1; }

# FIX: Use -x instead of -f to avoid accidentally killing this script

log_info "Cleaning up old processes..."

pkill -x "usbmuxd" || true

pkill -x "usbmuxd_proxy" || true

rm -f "$SOCKET" "$PIDFILE"

log_info "Starting the usbmuxd daemon..."

mkdir -p "$(dirname "$SOCKET")"

# Start the background daemon and redirect the log

nohup termux-usb -E -e "$PROXY_BIN --socket $SOCKET --pidfile $PIDFILE" "$device" >> "$LOGFILE" 2>&1 &

# Wait for the socket to appear (maximum 10 seconds)

local timeout=10

while [[ $timeout -gt 0 ]]; do

if [[ -S "$SOCKET" ]]; then break; fi

sleep 1

((timeout--))
done

if [[ -S "$SOCKET" ]]; then

log_info "usbmuxd is ready at $SOCKET"

else

log_error "Startup failed. Please check the log: cat $LOGFILE"

fi
}

stop_usbmuxd() {

log_info "Stopping usbmuxd..."

pkill -x "usbmuxd" || true

pkill -x "usbmuxd_proxy" || true

rm -f "$SOCKET" "$PIDFILE"

log_info "Stopped."

}

show_status() {
if pgrep -x "usbmuxd" > /dev/null; then

echo -e "Status: ${GREEN}RUNNING${NC}"

idevice_id -l || echo "Device not detected via socket."

else

echo -e "Status: ${RED}STOP${NC}"

fi
}

interactive_menu() {
while true; do

echo -e "\n${BLUE}=== Termux-Usbmuxd Pro (Stable) ===${NC}"

echo "1) Start usbmuxd"

echo "2) Stop usbmuxd"

echo "3) Pair"

echo "4) View info"

echo "q) Exit"

echo -n "Select: "
read -r opt

case $opt in

1) start_usbmuxd ;;

2) stop_usbmuxd ;;

3) idevicepair pair ;;

4) ideviceinfo ;;

q) exit 0 ;;
esac
  done
}

if [[ $# -eq 0 ]]; then interactive_menu; exit 0; fi
case "$1" in
  start) start_usbmuxd ;;
  stop) stop_usbmuxd ;;
  pair) ideapair pair ;;
  info) ideaviceinfo ;;
  *) interactive_menu ;;
esac
